  "keyFeatures": [
    "Unified ExchangeRestClient and ExchangeSocketClient for 26+ exchanges",
    "Exchange-agnostic shared interfaces (ISpotTickerRestClient, IFuturesOrderRestClient, etc.)",
    "Multi-exchange requests and subscriptions in a single call",
    "Automatic WebSocket reconnection management",
    "Client-side rate limiting with configurable behavior",
    "Client-side order book support via ExchangeOrderBookFactory",
    "Multi-user client management via ExchangeUserClientProvider",
    "Dependency injection support via AddCryptoClients()",
    "Strongly typed models and enum mappings",
    "Support for multiple API environments per exchange"
  ],
  "publicApiSurface": [
    "ExchangeRestClient",
    "ExchangeSocketClient",
    "ExchangeUserClientProvider",
    "ExchangeOrderBookFactory",
    "ExchangeTrackerFactory",
    "IExchangeRestClient",
    "IExchangeSocketClient",
    "IExchangeUserClientProvider",
    "IExchangeOrderBookFactory",
    "IExchangeTrackerFactory",
    "ExchangeCredentials",
    "GlobalExchangeOptions",
    "Exchanges.All",
    "Platforms.All",
    "ServiceCollectionExtensions.AddCryptoClients()"
  ]
